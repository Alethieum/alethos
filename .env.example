# Alethieum API Configuration
# Copy this file to .env and fill in your actual API key

# Your Alethieum API key from https://www.aiwsdao.com
AIWS_API_KEY=your_api_key_here

# API Base URL (usually doesn't need to be changed)
AIWS_BASE_URL=https://api.aiwsdao.com/v1/

# Default model to use (can be overridden per agent)
AIWS_DEFAULT_MODEL=aiws/gpt-oss-20b